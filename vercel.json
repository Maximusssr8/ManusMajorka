{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && node scripts/build-api.mjs",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.serverless.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.serverless.js": {
      "maxDuration": 300
    }
  }
}
