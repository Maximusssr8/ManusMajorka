{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "silent": true
  },
  "buildCommand": "vite build && node scripts/build-api.mjs",
  "outputDirectory": "dist/public",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://api.apify.com https://developers.cjdropshipping.com https://*.supabase.co https://api.stripe.com https://api.tavily.com https://app.posthog.com https://aliexpress-datahub.p.rapidapi.com; frame-src https://js.stripe.com; object-src 'none';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer-when-downgrade"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.serverless.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.serverless.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-trends",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refresh-shops",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/refresh-products",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/collect-tiktok-cc",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/scrape-tiktok-shop",
      "schedule": "30 */3 * * *"
    },
    {
      "path": "/api/cron/scrape-aliexpress-trending",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/collect-cj",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/scrape-aliexpress-categories",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/scrape-amazon",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/collect-trends",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/harvest-apify-runs",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-pipeline",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/cleanup-database",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refresh-scores",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/check-dead-links",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/purge-dead-products",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/ae-bestsellers",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ae-hot-products",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/refresh-hotproducts",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/trend-pipeline",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/cj-refresh",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 * * * *"
    }
  ]
}