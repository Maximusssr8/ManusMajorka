{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && node_modules/.bin/esbuild api/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.serverless.cjs --log-level=warning",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.serverless.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.serverless.cjs": {
      "maxDuration": 60
    }
  }
}
