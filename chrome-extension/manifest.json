{
  "manifest_version": 3,
  "name": "Majorka — AliExpress Intelligence",
  "version": "1.0.0",
  "description": "See Majorka winning scores, trend velocity, and ad angles directly on AliExpress product pages.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.aliexpress.com/*", "https://*.majorka.io/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.aliexpress.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
