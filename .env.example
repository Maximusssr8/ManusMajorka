# ─── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase Postgres) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Anthropic (Claude AI chat) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Tavily (web search / extract) ────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Forge API (optional — structured tool backend) ───────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# Client-side Forge API (for Google Maps proxy in the browser)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ─── Firecrawl (optional — website scraping) ──────────────────
FIRECRAWL_API_KEY=

# ─── AWS S3 (optional — file uploads) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ─── Resend (transactional email) ─────────────────────────────
# Drives welcome / trial / payment emails (see server/lib/email.ts).
# Get a key at https://resend.com/api-keys
# Without RESEND_API_KEY (and without POSTMARK_API_KEY fallback), the
# transactional dispatcher returns { ok: false, reason: 'no_provider' }.
RESEND_API_KEY=re_...
# Optional fallback provider — used only if RESEND_API_KEY is unset.
POSTMARK_API_KEY=

# ─── Stripe (payments / subscriptions) ────────────────────────
# Live mode — ALL five variables below must be present in Vercel for
# /api/stripe/checkout-session to succeed. The cadence-specific IDs take
# priority; the legacy cadence-less IDs are used as fallback.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly ($99 AUD / $199 AUD)
STRIPE_BUILDER_PRICE_ID_MONTHLY=price_...
STRIPE_SCALE_PRICE_ID_MONTHLY=price_...
# Annual (20% off — optional, only required if the UI annual toggle is used)
STRIPE_BUILDER_PRICE_ID_ANNUAL=price_...
STRIPE_SCALE_PRICE_ID_ANNUAL=price_...
# Legacy fallbacks (still honored for backwards compat with older checkouts)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUILDER_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# ─── Shopify OAuth ───────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=https://majorka.io/api/shopify/callback
SHOPIFY_SCOPES=write_products,write_content,read_themes,write_themes

# ─── AliExpress Affiliate API ───────────────────────────────
ALIEXPRESS_APP_KEY=your_app_key_from_portals.aliexpress.com
ALIEXPRESS_APP_SECRET=your_app_secret
ALIEXPRESS_TRACKING_ID=majorka_au

# ─── Google Stitch MCP (UI design generation) ───────────────
GOOGLE_STITCH_API_KEY=your_key_here

# ─── Ad Image Generation (Ads Studio) ───────────────────────
# Preferred: fal.ai — fast + high quality (fal-ai/flux/schnell).
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=
# Fallback: OpenAI gpt-image-1. Either FAL_KEY or OPENAI_API_KEY enables
# the "Visual Creative" card in Ads Studio; without either, the UI shows
# an honest disabled state.
OPENAI_API_KEY=

# ─── AliExpress product pipeline (CRITICAL) ─────────────────
# Required for the pintostudio~aliexpress-product-search actor used by the
# 6-hourly cron /api/cron/apify-pipeline and /api/admin/trigger-pipeline.
# Without this set in Vercel, raw_collected will be 0 on every run.
# Get from https://console.apify.com/settings/integrations
APIFY_API_KEY=

# ─── Admin + cron auth ───────────────────────────────────────
# Must be ≥32 chars. Required for /api/admin/trigger-pipeline,
# /api/admin/test-apify, /api/admin/refresh-videos and all admin endpoints.
ADMIN_TOKEN=
# Vercel Cron Bearer — required for every /api/cron/* route to accept
# requests from outside the platform's cron invoker.
CRON_SECRET=

# ─── Rate limiting (Upstash Redis) ───────────────────────────
# If unset, rate limits fail-open with a single warn log at boot.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Error tracking (Sentry) ─────────────────────────────────
# Optional. If unset, error-capture is a silent no-op.
SENTRY_DSN=
VITE_SENTRY_DSN=
