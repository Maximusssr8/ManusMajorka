# ============================================================
# Majorka Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Core / Server ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Authentication ---
JWT_SECRET=your-jwt-secret-here

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Media / Image Search ---
PEXELS_API_KEY=your-pexels-api-key-here

# --- Web Scraping ---
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# --- Web Search (Tavily) ---
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# --- Email (Resend) - Optional: if not set, verification codes print to console ---
RESEND_API_KEY=re_your-resend-api-key-here

# --- OAuth / SSO (Optional: needed for Google/Apple sign-in) ---
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_APP_ID=your-app-id

# --- Owner / Admin (Optional) ---
OWNER_OPEN_ID=your-owner-open-id

# --- Forge / Built-in AI Proxy (Optional: platform-provided) ---
BUILT_IN_FORGE_API_URL=https://forge.example.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key-here

# --- Client-side Forge (Optional: Vite injects VITE_* vars into the client bundle) ---
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.example.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com

# --- Analytics (Umami) - Optional: referenced in index.html ---
VITE_ANALYTICS_ENDPOINT=https://your-analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
