# ─── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase Postgres) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Anthropic (Claude AI chat) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Tavily (web search / extract) ────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Forge API (optional — structured tool backend) ───────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# Client-side Forge API (for Google Maps proxy in the browser)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ─── Firecrawl (optional — website scraping) ──────────────────
FIRECRAWL_API_KEY=

# ─── AWS S3 (optional — file uploads) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ─── Stripe (payments / subscriptions) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── Shopify OAuth ───────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=https://majorka.io/api/shopify/callback
SHOPIFY_SCOPES=write_products,write_content,read_themes,write_themes

# ─── AliExpress Affiliate API ───────────────────────────────
ALIEXPRESS_APP_KEY=your_app_key_from_portals.aliexpress.com
ALIEXPRESS_APP_SECRET=your_app_secret
ALIEXPRESS_TRACKING_ID=majorka_au

# ─── Google Stitch MCP (UI design generation) ───────────────
GOOGLE_STITCH_API_KEY=your_key_here
